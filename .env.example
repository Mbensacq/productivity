# ──────────────────────────────────────────────────────────────────────────
# Frontend env (PUBLIC — injected at build time, safe to ship in the bundle).
# Copy to `.env.local` for local dev. Never put secrets here.
# ──────────────────────────────────────────────────────────────────────────

# Supabase project (Project Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google OAuth client id (Google Cloud Console → Credentials → OAuth Web client)
# PUBLIC value. The client SECRET must NOT be here — it only lives as a Supabase
# Edge Function secret.
VITE_GOOGLE_CLIENT_ID=

# Base path for the build. "/" for local dev / custom domain.
# For GitHub Pages project sites use "/<repo-name>/" (CI sets this automatically).
VITE_BASE_PATH=/

# Optional: enable Sentry error reporting (disabled by default).
VITE_SENTRY_DSN=

# ──────────────────────────────────────────────────────────────────────────
# SERVER-ONLY secrets — DO NOT put these in any VITE_ var or the frontend.
# Set them as Supabase Edge Function secrets / GitHub Actions secrets.
# Listed here only for documentation. See SETUP.md.
# ──────────────────────────────────────────────────────────────────────────
# GOOGLE_CLIENT_SECRET=          # Edge Function secret only
# SUPABASE_SERVICE_ROLE_KEY=     # CI + Edge Functions only
# SUPABASE_ACCESS_TOKEN=         # CI only (supabase CLI)
# SUPABASE_PROJECT_REF=          # CI only
# REFRESH_TOKEN_ENC_KEY=         # Edge Function secret (refresh-token encryption)
